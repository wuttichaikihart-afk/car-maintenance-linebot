{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/.netlify/functions/webhook",
      "destination": "/api/index.js"
    },
    {
      "source": "/.netlify/functions/api-register",
      "destination": "/api/index.js"
    }
  ]
}
